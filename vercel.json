{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gradtracker.onrender.com/api/:path*"
    },

    {
      "source": "/__/auth/:path*",
      "destination": "https://grad-tracker-app.firebaseapp.com/__/auth/:path*"
    },

    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}